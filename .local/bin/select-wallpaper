#!/bin/bash
WALLPAPER_DIR="/home/bubba/.config/omarchy/current/theme/backgrounds"
# Log file for debugging
LOG="/tmp/select-wallpaper.log"
echo "===== $(date) =====" >> "$LOG"
# Use rofi or fuzzy finder to select wallpaper
SELECTED=$(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.png" \) | \
    sed "s|$WALLPAPER_DIR/||" | \
    sort | \
    rofi -dmenu -i -p "Select Wallpaper" -theme-str 'window {width: 50%;}')
echo "Selected: $SELECTED" >> "$LOG"
if [ -n "$SELECTED" ]; then
    FULL_PATH="$WALLPAPER_DIR/$SELECTED"
    echo "Full path: $FULL_PATH" >> "$LOG"
    /home/bubba/.local/bin/change-wallpaper "$FULL_PATH" >> "$LOG" 2>&1
else
    echo "No selection made" >> "$LOG"
fi
