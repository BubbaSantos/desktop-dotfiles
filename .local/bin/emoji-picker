#!/bin/bash
# ~/.local/bin/emoji-picker
EMOJIS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/emojis/all_emojis.txt"
USAGE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/emojis/usage-count.txt"

if [ ! -f "$EMOJIS_FILE" ]; then
    notify-send "Emoji Picker" "Emojis file not found: $EMOJIS_FILE"
    exit 1
fi

touch "$USAGE_FILE"

get_usage_count() {
    local key="$1"
    grep "^$key:" "$USAGE_FILE" 2>/dev/null | cut -d: -f2 || echo "0"
}

increment_usage() {
    local key="$1"
    local count=$(get_usage_count "$key")
    local new_count=$((count + 1))
    grep -v "^$key:" "$USAGE_FILE" > "${USAGE_FILE}.tmp" 2>/dev/null || true
    echo "$key:$new_count" >> "${USAGE_FILE}.tmp"
    mv "${USAGE_FILE}.tmp" "$USAGE_FILE"
}

if [[ "$1" == "--pick" ]]; then
    # Build display list: "😀  grinning face  | cheerful | happy ..."
    # Store emoji as first field for easy extraction
    display_list=$(awk -F'\t' '{
    emoji=$1; name=$4; keywords=$5
    # pad name to fixed width so keywords column stays hidden off-screen
    printf "%s\t%-50s\t%s\n", emoji, name, keywords
}' "$EMOJIS_FILE")

selected=$(echo "$display_list" | fzf \
    --prompt="  Emoji > " \
    --layout=reverse \
    --border=rounded \
    --no-info \
    --no-scrollbar \
    --delimiter='\t' \
    --with-nth=1,2)

    [[ -z "$selected" ]] && exit 0
    echo "$selected" > /tmp/emoji-selected
    exit 0
fi

alacritty --title "emoji-picker" \
           --option "font.size=14" \
           -e bash ~/.local/bin/emoji-picker --pick
wait

[[ ! -f /tmp/emoji-selected ]] && exit 0
selected=$(cat /tmp/emoji-selected)
rm -f /tmp/emoji-selected
[[ -z "$selected" ]] && exit 0

# Extract emoji (first field)
emoji=$(echo "$selected" | awk '{print $1}')
increment_usage "$emoji"

if [ -n "$emoji" ]; then
    echo -n "$emoji" | wl-copy
    sleep 0.2
    wtype -M ctrl v -m ctrl
else
    notify-send "Emoji Picker" "Could not extract emoji"
fi
